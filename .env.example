# Contact details surfaced in the UI.
# All values are optional — sensible defaults live in lib/site-config.ts —
# but every deployment should override them with real contact info.

# Digits-only (country code + number) used to build https://wa.me/ URLs.
NEXT_PUBLIC_WHATSAPP_NUMBER=573001234567

# Human-readable WhatsApp number shown in contact cards and form placeholders.
NEXT_PUBLIC_WHATSAPP_DISPLAY="+57 300 123 4567"

# Landline phone number displayed in the footer and contact section.
NEXT_PUBLIC_CONTACT_PHONE="+57 (5) 123-4567"

# Primary inbox for general inquiries.
NEXT_PUBLIC_CONTACT_EMAIL=info@guajiraemprende.gov.co

# Inbox shown on opportunity detail pages for application support.
NEXT_PUBLIC_SUPPORT_EMAIL=ayuda@guajiraemprende.gov.co
