# Public contact information. Used in the navigation, footer, detail pages,
# and the WhatsApp floating button. `NEXT_PUBLIC_*` variables are inlined
# into the client bundle at build time, so they must not contain secrets.
NEXT_PUBLIC_WHATSAPP_NUMBER=573001234567
NEXT_PUBLIC_CONTACT_PHONE="+57 (5) 123-4567"
NEXT_PUBLIC_CONTACT_EMAIL=info@guajiraemprende.gov.co
NEXT_PUBLIC_SUPPORT_EMAIL=ayuda@guajiraemprende.gov.co

# Email delivery. If RESEND_API_KEY is unset, both form handlers fall back
# to logging submissions to the server console — useful during local dev.
# RESEND_API_KEY=re_xxx
# RESEND_FROM="Guajira Emprende <no-reply@guajiraemprende.gov.co>"

# Inbox that receives contact-form and community-join notifications.
# Falls back to NEXT_PUBLIC_CONTACT_EMAIL when not set.
# CONTACT_FORM_TO=equipo@guajiraemprende.gov.co
